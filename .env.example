# Telegram API
API_ID=YOUR_API_ID
API_HASH=your_api_hash_here

# Session security
SESSION_PASSWORD=your_secure_password_here
SESSION_FILE=session.tg

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database
DB_PATH=data/tg_mod.db

# Cache
CACHE_DIR=data/cache
CACHE_MAX_SIZE_MB=500

# Features
EXPERIMENTAL_FEATURES=false
DEBUG=false
